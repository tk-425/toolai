{
  "name": "toolai",
  "version": "0.3.2",
  "private": true,
  "type": "module",
  "description": "Interactive CLI for local agent and skill management.",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "bin": {
    "toolai": "./bin/run.js"
  },
  "oclif": {
    "bin": "toolai",
    "commands": "./dist/src/commands",
    "dirname": "toolai",
    "topicSeparator": " ",
    "theme": {
      "bin": "cyan",
      "dollarSign": "cyan",
      "version": "yellow",
      "sectionHeader": "blueBright",
      "sectionDescription": "dim",
      "command": "greenBright",
      "commandSummary": "white",
      "topic": "magentaBright",
      "flag": "cyanBright",
      "flagSeparator": "gray",
      "flagDefaultValue": "yellow",
      "flagOptions": "magenta",
      "flagRequired": "redBright"
    },
    "topics": {
      "config": {
        "name": "config",
        "description": "Manage toolai configuration",
        "subtopics": {
          "platforms": {
            "name": "platforms",
            "description": "Manage custom global platforms"
          }
        }
      }
    }
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@oclif/core": "^4.10.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.2"
  }
}
