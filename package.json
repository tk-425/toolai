{
  "name": "toolai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Interactive CLI for local agent and skill management.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "toolai": "./bin/run.js"
  },
  "oclif": {
    "bin": "toolai",
    "commands": "./dist/src/commands",
    "dirname": "toolai",
    "topicSeparator": " "
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@oclif/core": "^4.10.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
